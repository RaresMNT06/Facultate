    36                                              
    37 00000019 3C20                                cmp al, ' '
    38 0000001B 7404                                je fisier
    39 0000001D AA                                      stosb           ;edi/nume_fisier numele fisierului
    40 0000001E 43                                      inc ebx                 ;numarul de litere
    41 0000001F EBF3                                    jmp bucla
    42                                              
    43                                              fisier:
    44 00000021 C6072E                                  mov byte [edi],"."
    45 00000024 C6470174                                mov byte [edi+1],"t"
    46 00000028 C6470278                                mov byte [edi+2],"x"
