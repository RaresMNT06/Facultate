    48 00000030 C6470400                                mov byte [edi+4],0
    49                                                  
    50 00000034 68[17000000]                            push dword mod_acces
    51 00000039 68[20000000]                            push dword nume_fisier
    52 0000003E FF15[00000000]                          call [fopen]
    53 00000044 83C408                                  add esp,4*2
