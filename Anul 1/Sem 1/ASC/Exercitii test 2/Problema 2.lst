    19 00000017 7700                        mod_acces db "w",0
    20 00000019 256400                      format db "%d",0
    21 0000001C 00000000                    descriptor_fisier dd 0
    22 00000020 00<rept>                    nume_fisier times 100 db 0
    23 00000084 00000000                    numar_litere dd 0
    24                                  ; our code starts here
    25                                  segment code use32 class=code
    26                                      start:
    27                                          ; ...
    28 00000000 BB00000000                      mov ebx, 0
    29 00000005 BE[00000000]                    mov esi, sir
