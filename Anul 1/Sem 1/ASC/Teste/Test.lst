     1                                  ;Se considera urmatoarea problema si solutia propusa(codul sursa). Este solutia corecta?
     2                                  ;Daca considerati ca este necesar, modificati codul pentru a rezolva problema.
     3                                  ;Asigurati-va ca codul se asambleaza fara erori sau advertismente.
     4                                  ;--------------------------------------------------------------------------------------------------
     5                                  ; Se dau cuvantul A si octetul B. Se cere dublucuvantul C:
     6                                  ; bitii 0-2 ai lui C coincid cu bitii 5-7 ai lui B
     7                                  ; bitii 3-7 ai lui C coincid cu bitii 0-4 ai lui A
     8                                  ; bitii 8-9 ai lui C sunt egali cu 1
     9                                  ; bitii 10-15 ai lui C coincid cu bitii 6-11 ai lui A
    10                                  ; bitii 16-31 ai lui C sunt bitii coincid cu bitii negati lui A
    11                                  ;Sa se calculeze in interpretare cu semn(d-e+g)/f -e*2, unde d-byte, e-word, f=doubleword, g=qword
    12                                  bits 32 ; assembling for the 32 bits architecture
    13                                  
    14                                  ; declare the EntryPoint (a label defining the very first instruction of the program)
    15                                  global start        
    16                                  
    17                                  ; declare external functions needed by our program
    18                                  extern exit               ; tell nasm that exit exists even if we won't be defining it
    19                                  import exit msvcrt.dll    ; exit is a function that ends the calling process. It is defined in msvcrt.dll
    20                                                            ; msvcrt.dll contains exit, printf and all the other important C-runtime specific functions
    21                                  
    22                                  ; our data is declared here (the variables needed by our program)
    23                                  segment data use32 class=data
    24                                      ; ...
    25 00000000 96D2                        a dw 1101001010010110b
    26 00000002 9B                          b db 10011011b
    27 00000003 00000000                    c dd 0
    28 00000007 0A                          d db 10
    29 00000008 0300                        e dw 3
    30 0000000A 04000000                    f dd 4
    31 0000000E 0200000000000000            g dq 2
    32                                  ; our code starts here
    33                                  segment code use32 class=code
    34                                      start:
    35                                          ; ...
    36 00000000 66BB0000                        mov bx,0
    37 00000004 A0[02000000]                    mov al, [b]
    38 00000009 C0E805                          shr al, 5 ;ca sa ducem pe pozitia 0-2 pentru a pune in c ar trebui sa shiftam spre dreapta cu 5
    39 0000000C 2407                            and al, 07h
    40 0000000E 08C3                            or  bl,al ;punem in bl pe al nu pe ax iar bl= 0000 0100
    41 00000010 66A1[00000000]                  mov ax, [a]
    42 00000016 66C1E003                        shl ax, 3 ; bitii 0-4 a lui o o sa fie pe pozitiile 7-3
    43 0000001A 6625F800                        and ax, 0000000011111000b ; aici facem and nu or
    44 0000001E 6609C3                          or bx, ax ; bx= 0000 0000 1011 0100
    45 00000021 80CF03                          or bh, 03h
    46 00000024 66A1[00000000]                  mov ax, [a]
    47 0000002A 66C1E004                        shl ax, 4 ; pentru a adauga la c urmatorii bitii 6 11 a lui a se vor muta spre stanga
    48 0000002E 662500FC                        and ax, 1111110000000000b
    49 00000032 6609C3                          or bx, ax
    50 00000035 66091D[03000000]                or [c], bx 
    51 0000003C 0FB705[00000000]                movzx eax, word[a]; a nu este dword este word
    52 00000043 C1C010                          rol eax, 16 
    53 00000046 F7D0                            not eax
    54 00000048 250000FFFF                      and eax, 0FFFF0000h
    55 0000004D 0905[03000000]                  or [c], eax ; c= 2D692BB4h
    56 00000053 A0[07000000]                    mov al, [d]
    57 00000058 6698                            cbw ; AL devine AX
    58 0000005A 662B05[08000000]                sub ax, [e] ;e este word si nu putem face scaderea
    59 00000061 98                              cwde ; modifica din cwd in cwde pentru a converti dupa in qword
    60 00000062 99                              cdq 
    61 00000063 0305[0E000000]                  add eax, dword[g]
    62 00000069 0315[10000000]                  add edx, dword[g+2]
    63 0000006F F73D[0A000000]                  idiv dword [f] ; lui f trebuie declarata dimensiunea
    64 00000075 89C3                            mov ebx, eax
    65 00000077 B002                            mov al, 2
    66 00000079 66F725[08000000]                mul word[e]
    67 00000080 6652                            push dx
    68 00000082 6650                            push ax
    69 00000084 58                              pop eax ;nu dam pop la al, dam pop la eax
    70 00000085 29C3                            sub ebx, eax
    71                                          ; exit(0)
    72 00000087 6A00                            push    dword 0      ; push the parameter for exit onto the stack
    73 00000089 FF15[00000000]                  call    [exit]       ; call exit to terminate the program
