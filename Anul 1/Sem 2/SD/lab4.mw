<Group hide-input="false" labelreference="L28" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#3 a
restart;
with(DEtools):
ec1:=diff(x(t),t)=r*x(t);
cond_init:=x(0)=x0;
sist:=ec1,cond_init;
sol:=dsolve({sist},{x(t)});
solM:=unapply(rhs(sol),r,t,x0);

ec2:=diff(x(t),t)=r0*x(t)*(1-(x(t)/K));
cond_init2:=x(0)=x0;
sist2:=ec2,cond_init2;
sol2:=dsolve({sist2},{x(t)});
solV:=unapply(rhs(sol2),r0,t,x0,K);</Text-field>
</Input>
