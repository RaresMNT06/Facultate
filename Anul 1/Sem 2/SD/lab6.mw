<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ex.3
#a
f1:=(x,y)-&gt;y;
f2:=(x,y)-&gt;x*(1-x^2)+y;
ec1:=diff(x(t),t)=f1(x(t),y(t));
ec2:=diff(y(t),t)=f2(x(t),y(t));
sist2:=ec1,ec2;
pct_ech3:=solve({f1(x,y)=0,f2(x,y)=0},{x,y});
J:=jacobian([f1(x,y),f2(x,y)],[x,y]);
A1:=subs(pct_ech3[1,1],pct_ech3[1,2],eval(J));
eigenvals(A1);</Text-field>
</Input>
