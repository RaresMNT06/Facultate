<Group hide-input="false" labelreference="L1" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"># ex.1
#a
restart;
with(DEtools):
with(plots):
f1:=x-&gt;x^2-2*x;
ec1:=diff(x(t),t)=f1(x(t));
pct_ech:=solve(f1(x)=0,x);
D(f1)(0);
D(f1)(2);
DEplot(ec1, x(t), t = -2 .. 2, x = -1 .. 3,[[x(0) = -1], [x(0) = 0], [x(0) = 1], [x(0) = 2], [x(0) = 3]]);</Text-field>
</Input>
