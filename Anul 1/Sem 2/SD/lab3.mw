<Group hide-input="false" labelreference="L35" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#3-a
restart;
with(DEtools): with(plots):
ec1:=diff(x(t),t)=x(t)+y(t);
ec2:=diff(y(t),t)=-2*x(t)+4*y(t);
sist:=ec1,ec2;
cond_in1:=x(0)=3, y(0)=0;
cond_in2:=x(0)=0, y(0)=3;
cond_in3:=x(0)=-3, y(0)=0;
cond_in4:=x(0)=0, y(0)=-3;
sol1:=dsolve({sist,cond_in1},{x(t),y(t)});
xx1:=unapply(rhs(sol1[1]),t);
yy1:=unapply(rhs(sol1[2]),t);
plot([xx1(t),yy1(t)],t=-5..5,color=[red,blue]);
sol2:=dsolve({sist,cond_in2},{x(t),y(t)});
xx2:=unapply(rhs(sol2[1]),t);
yy2:=unapply(rhs(sol2[2]),t);
plot([xx2(t),yy2(t)],t=-5..5,color=[red,blue]);
sol3:=dsolve({sist,cond_in3},{x(t),y(t)});
xx3:=unapply(rhs(sol3[1]),t);
yy3:=unapply(rhs(sol3[2]),t);
plot([xx3(t),yy3(t)],t=-5..5,color=[red,blue]);
sol4:=dsolve({sist,cond_in4},{x(t),y(t)});
xx4:=unapply(rhs(sol4[1]),t);
yy4:=unapply(rhs(sol4[2]),t);
plot([xx4(t),yy4(t)],t=-5..5,color=[red,blue]);
</Text-field>
</Input>
