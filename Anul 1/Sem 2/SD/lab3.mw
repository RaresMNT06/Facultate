<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#2-d
ec1:=diff(x(t),t)=-x(t)+3*y(t)+3*z(t)+27*(t^2);
ec2:=diff(y(t),t)=2*x(t)-2*y(t)-5*z(t)+3*t;
ec3:=diff(z(t),t)=-2*x(t)+3*y(t)+6*z(t)+3;
sist:=ec1,ec2;
cond_in:=x(0)=50, y(0)=-30, z(0)=26;
sol:=dsolve({sist,cond_in},{x(t),y(t),z(t)});
xx:=unapply(rhs(sol[1]),t);
yy:=unapply(rhs(sol[2]),t);
zz:=unapply(rhs(sol[3]),t);
plot([xx(t),yy(t),zz(t)],t=-5..5,color=[red,blue]);</Text-field>
</Input>
