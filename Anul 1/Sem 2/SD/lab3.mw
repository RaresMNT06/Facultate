<Group hide-input="false" labelreference="L3" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">#1-c
ec1:=diff(x(t),t)=x(t)-y(t)+z(t);
ec2:=diff(y(t),t)=x(t)+y(t)-z(t);
ec3:=diff(z(t),t)=-y(t)+2*z(t);
